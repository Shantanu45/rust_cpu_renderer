{
  "languages": {
    "Rust": {
      "format_on_save": "on",
      "formatter": "language_server"
    }
  },
  "lsp": {
    "rust-analyzer": {
      "enable_lsp_tasks": true,
      "initialization_options": {
        "checkOnSave": true,
        "cargo": {
          "allTargets": true
        },
        "check": {
          "command": "check"
        }
      }
    }
  }
}
